<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="เว็บไซต์แสดงผลงานและทักษะของ Somchai">
    <title>ผลงานของ SOMCHAI</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>

    <!-- ส่วนหัวของเว็บ -->
    <header>
        <h1>สวัสดี! ผมคือ อิรากรณ์ ใจกระจ่าง</h1>
        <p>ยินดีต้อนรับสู่ความภาคภูมิใจของผม</p>
    </header>

    <!-- ส่วนเกี่ยวกับตัวเอง -->
    <section id="about">
        <h2>เกี่ยวกับผม</h2>
        <p>
            ผมเป็นนักพัฒนาซอฟต์แวร์ที่มีความหลงใหลในการสร้างสรรค์สิ่งใหม่ ๆ
            สนใจด้านเทคโนโลยีและทักษะที่ช่วยพัฒนาตนเองอยู่เสมอ
        </p>
    </section>

    <!-- ส่วนแสดงผลงาน -->
    <section id="projects">
        <h2>ผลงานของผม</h2>

        <div class="project">
            <h3>เว็บไซต์ Portfolio</h3>
            <p>เว็บไซต์ที่ใช้แนะนำตนเองและแสดงผลงานที่ผ่านมา</p>
        </div>

        <div class="project">
            <h3>แอปพลิเคชันจัดการงาน</h3>
            <p>แอปพลิเคชันที่ช่วยให้ผู้ใช้งานจัดการงานได้อย่างมีประสิทธิภาพ</p>
        </div>
    </section>

    <!-- ส่วนแสดงทักษะ -->
    <section id="skills">
        <h2>ทักษะของผม</h2>
        <ul>
            <li>HTML, CSS, JavaScript</li>
            <li>Python, Django</li>
            <li>Git และ GitHub</li>
            <li>การออกแบบ UI/UX</li>
        </ul>
    </section>

    <!-- ส่วนติดต่อ -->
    <footer>
        <p>
            ติดต่อผมได้ที่ :
            <a href="mailto:somchai@example.com">
                somchai@example.com
            </a>
        </p>

        <p>
            &copy; <span id="year"></span> SOMCHAI.
            All rights reserved.
        </p>
    </footer>

    <!-- JavaScript -->
    <script>
        document.getElementById("year").textContent =
            new Date().getFullYear();
    </script>

</body>
</html>
